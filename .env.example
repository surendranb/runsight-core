# Netlify Function variables (required)
# Set these in the Netlify dashboard for production and preview deploys.
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=https://your-site.netlify.app/auth/callback
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
OPENWEATHER_API_KEY=your_openweather_api_key

# Optional but recommended session signing secret.
# If unset, RunSight falls back to SUPABASE_SERVICE_KEY for session signing.
SESSION_SECRET=replace_with_a_long_random_string
